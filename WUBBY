<html lang="en">
<head> <meta name="robots" content="noindex, nofollow">
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1"/>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,300;1,300;1,400&family=EB+Garamond:ital,wght@0,400;1,400&family=Jost:wght@300;400&display=swap" rel="stylesheet"/>
<style>
:root{--ink:#1c1008;--parch:#faf5ec;--blush:#d4826e;--deep:#7a3728;--gold:#c9a652;--ivory:#fff8ef}
*{margin:0;padding:0;box-sizing:border-box}
html{font-size:16px}
body{background:var(--parch);font-family:'EB Garamond',serif;color:var(--ink);overflow-x:hidden;min-height:100vh}

/* Petals */
#sky{position:fixed;inset:0;pointer-events:none;z-index:0;overflow:hidden}
.petal{position:absolute;top:-80px;border-radius:150% 0 150% 0;opacity:0;animation:drift linear infinite}
@keyframes drift{0%{transform:translateY(0) rotate(0deg);opacity:0}8%{opacity:.55}88%{opacity:.4}100%{transform:translateY(115vh) rotate(500deg) translateX(30px);opacity:0}}

/* Pages */
.page{position:relative;z-index:1;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:clamp(30px,5vw,80px) clamp(16px,4vw,40px)}
.hidden{display:none!important}

/* ── GATE PAGE ── */
#gate{background:radial-gradient(ellipse 80% 60% at 20% 30%,rgba(212,130,110,.22),transparent 70%),radial-gradient(ellipse 60% 50% at 80% 70%,rgba(201,166,82,.15),transparent 65%),var(--parch)}
.gw{text-align:center;max-width:520px;width:100%;animation:riseIn 1.1s cubic-bezier(.22,.61,.36,1) both}
@keyframes riseIn{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:translateY(0)}}
.lily{margin-bottom:clamp(16px,3vw,28px);display:inline-block;animation:breathe 4s ease-in-out infinite}
@keyframes breathe{0%,100%{transform:scale(1) rotate(-1deg)}50%{transform:scale(1.06) rotate(1deg)}}

h1.gh{font-family:'Playfair Display',serif;font-size:clamp(2.4rem,5vw,4.2rem);font-weight:300;color:var(--deep);line-height:1.15;margin-bottom:8px}
h1.gh em{font-style:italic;color:var(--blush)}
.by{font-family:'Jost',sans-serif;font-size:clamp(.7rem,.9vw,.85rem);letter-spacing:.22em;text-transform:uppercase;color:var(--blush);margin-bottom:clamp(24px,4vw,44px);opacity:.8}

.card{background:rgba(255,252,245,.88);border:1px solid rgba(212,130,110,.22);backdrop-filter:blur(14px);border-radius:20px;padding:clamp(24px,4vw,42px) clamp(20px,4vw,40px);box-shadow:0 12px 48px rgba(122,55,40,.09)}
label.fl{font-family:'Jost',sans-serif;font-size:clamp(.65rem,.75vw,.75rem);letter-spacing:.18em;text-transform:uppercase;color:var(--deep);display:block;margin-bottom:8px;text-align:left;opacity:.75}
input.fi{width:100%;padding:clamp(12px,1.5vw,16px) 18px;border:1px solid rgba(212,130,110,.28);border-radius:12px;background:rgba(255,255,255,.9);font-family:'EB Garamond',serif;font-size:clamp(1.1rem,1.5vw,1.25rem);color:var(--ink);outline:none;margin-bottom:18px;transition:border-color .3s,box-shadow .3s;-webkit-appearance:none}
input.fi:focus{border-color:var(--blush);box-shadow:0 0 0 3px rgba(212,130,110,.13)}
.hint{font-size:clamp(.78rem,.9vw,.9rem);color:var(--blush);font-style:italic;margin-top:-12px;margin-bottom:18px;text-align:left}
.btn{width:100%;padding:clamp(14px,1.8vw,18px);background:linear-gradient(140deg,var(--blush),var(--deep));color:#fff;border:none;border-radius:14px;font-family:'Playfair Display',serif;font-size:clamp(1rem,1.3vw,1.15rem);cursor:pointer;box-shadow:0 6px 22px rgba(122,55,40,.24);transition:transform .2s,box-shadow .2s;letter-spacing:.02em}
.btn:hover{transform:translateY(-2px);box-shadow:0 10px 28px rgba(122,55,40,.3)}
.btn:active{transform:translateY(0)}
.err{color:#c0392b;font-size:clamp(.84rem,1vw,.95rem);font-style:italic;margin-top:10px;display:none}

/* ── SIGN PAGE ── */
#sign{background:radial-gradient(ellipse 90% 50% at 50% 0%,rgba(212,130,110,.18),transparent 60%),var(--parch)}
#sign .wrap{text-align:center;max-width:640px;width:100%}
.sh{font-family:'Playfair Display',serif;font-size:clamp(1.9rem,4vw,3rem);font-weight:300;color:var(--deep);margin-bottom:6px}
.ss{font-family:'Jost',sans-serif;font-size:clamp(.65rem,.8vw,.78rem);letter-spacing:.2em;text-transform:uppercase;color:var(--blush);margin-bottom:clamp(20px,3vw,34px);opacity:.8}
.sc{background:rgba(255,252,245,.88);border:1px solid rgba(212,130,110,.2);border-radius:18px;padding:clamp(22px,3.5vw,36px) clamp(18px,4vw,40px);box-shadow:0 8px 36px rgba(122,55,40,.07);margin-bottom:22px}
.sp{font-family:'EB Garamond',serif;font-size:clamp(1.05rem,1.4vw,1.25rem);font-style:italic;line-height:1.9;margin-bottom:22px}
.sp span{color:var(--blush)}
input.si{width:100%;padding:clamp(10px,1.2vw,14px) 16px;border:none;border-bottom:2px solid rgba(212,130,110,.35);background:transparent;font-family:'Playfair Display',serif;font-size:clamp(1.3rem,2vw,1.7rem);font-style:italic;color:var(--deep);outline:none;transition:border-color .3s;text-align:center}
input.si:focus{border-color:var(--blush)}
input.si::placeholder{color:rgba(212,130,110,.38)}
.skip{font-family:'EB Garamond',serif;font-size:clamp(.88rem,1vw,1rem);font-style:italic;color:var(--blush);cursor:pointer;opacity:.65;margin-top:14px;display:inline-block;text-decoration:underline;text-underline-offset:3px}
.skip:hover{opacity:1}

/* ── MODAL ── */
.mb{display:none;position:fixed;inset:0;z-index:200;background:rgba(14,5,4,.75);backdrop-filter:blur(8px);align-items:center;justify-content:center;padding:24px}
.mb.open{display:flex}
.mbox{background:var(--ivory);border-radius:24px;padding:clamp(32px,5vw,52px) clamp(24px,4vw,44px);max-width:420px;width:100%;text-align:center;box-shadow:0 20px 70px rgba(0,0,0,.35);animation:popIn .4s cubic-bezier(.34,1.56,.64,1) both}
@keyframes popIn{from{transform:scale(.82);opacity:0}to{transform:scale(1);opacity:1}}
.mh{font-family:'Playfair Display',serif;font-size:clamp(1.7rem,2.5vw,2.1rem);font-weight:300;color:var(--deep);margin:14px 0 10px}
.mbody{font-family:'EB Garamond',serif;font-size:clamp(1rem,1.3vw,1.15rem);font-style:italic;line-height:1.85;margin-bottom:28px}
.mbody strong{color:var(--blush);font-style:normal}
.mbtns{display:flex;gap:12px}
.myes{flex:1;padding:clamp(13px,1.6vw,17px);background:linear-gradient(140deg,var(--blush),var(--deep));color:#fff;border:none;border-radius:12px;font-family:'Playfair Display',serif;font-size:clamp(.96rem,1.2vw,1.05rem);cursor:pointer;transition:transform .2s}
.myes:hover{transform:translateY(-2px)}
.mno{flex:1;padding:clamp(13px,1.6vw,17px);background:transparent;color:var(--deep);border:1px solid rgba(122,55,40,.3);border-radius:12px;font-family:'Playfair Display',serif;font-size:clamp(.96rem,1.2vw,1.05rem);cursor:pointer;transition:background .2s}
.mno:hover{background:rgba(122,55,40,.06)}

/* ── CERTIFICATE PAGE ── */
#certificate{background:radial-gradient(ellipse 90% 50% at 50% 0%,rgba(212,130,110,.18),transparent 60%),var(--parch)}
#certificate .wrap{text-align:center;max-width:700px;width:100%}
.cout{border:1px solid rgba(212,130,110,.35);border-radius:8px;padding:6px;box-shadow:0 0 60px rgba(212,130,110,.08)}
.cin{border:1px solid rgba(212,130,110,.2);border-radius:4px;padding:clamp(32px,6vw,64px) clamp(28px,6vw,56px);background:rgba(255,252,245,.6);position:relative}
.cc{position:absolute;font-size:clamp(.9rem,1.2vw,1.1rem);color:var(--blush);opacity:.5}
.tl{top:14px;left:14px}.tr{top:14px;right:14px}.bl{bottom:14px;left:14px}.br{bottom:14px;right:14px}
.clb{font-family:'Jost',sans-serif;font-size:clamp(.65rem,.8vw,.78rem);letter-spacing:.22em;text-transform:uppercase;color:var(--deep);opacity:.6;margin-bottom:14px;display:block}
.ctit{font-family:'Playfair Display',serif;font-size:clamp(1.3rem,2.5vw,2.1rem);font-weight:300;color:var(--deep);margin-bottom:6px}
.cnames{font-family:'Playfair Display',serif;font-size:clamp(1.6rem,4vw,3rem);font-style:italic;color:var(--ink);line-height:1.35;margin:clamp(14px,2vw,22px) 0}
.cnames .amp{color:var(--blush);font-size:.72em;font-style:normal}
.cbody{font-family:'EB Garamond',serif;font-size:clamp(.96rem,1.2vw,1.1rem);font-style:italic;color:rgba(28,16,8,.65);line-height:1.95;margin-bottom:18px}
.cdate{font-family:'Jost',sans-serif;font-size:clamp(.68rem,.8vw,.78rem);letter-spacing:.16em;text-transform:uppercase;color:var(--deep);opacity:.7}
.btg{margin-top:clamp(20px,3vw,32px);padding:clamp(11px,1.4vw,15px) clamp(28px,4vw,44px);background:transparent;border:1px solid rgba(212,130,110,.4);color:var(--blush);border-radius:50px;font-family:'EB Garamond',serif;font-size:clamp(.9rem,1.1vw,1.05rem);cursor:pointer;transition:all .3s}
.btg:hover{background:rgba(212,130,110,.1);color:var(--deep)}

/* ── HEARTS ── */
.hb{position:fixed;pointer-events:none;z-index:999;font-size:1.6rem;animation:hfly 1.8s ease-out forwards}
@keyframes hfly{0%{transform:translateY(0) scale(1);opacity:1}100%{transform:translateY(-200px) scale(.2);opacity:0}}

/* ── RESPONSIVE BREAKPOINTS ── */
/* iPad portrait (768px) */
@media(min-width:768px){
  .gw{max-width:500px}
  .card{padding:38px 42px}
  #sign .wrap{max-width:620px}
  .sc{padding:30px 38px}
  .mbtns{flex-direction:row}
}
/* iPad landscape / small laptop (1024px) */
@media(min-width:1024px){
  .gw{max-width:520px}
  .card{padding:44px 48px}
  #sign .wrap{max-width:660px}
  #certificate .wrap{max-width:720px}
  .mbox{max-width:440px;padding:52px 48px}
}
/* Full laptop (1280px+) */
@media(min-width:1280px){
  .gw{max-width:540px}
  h1.gh{font-size:4.4rem}
  .sh{font-size:3.2rem}
}
/* Small phones */
@media(max-width:480px){
  .card,.cin,.sc,.mbox{padding:20px 16px}
  .mbtns{flex-direction:column}
  .mbox{padding:28px 20px}
  input.fi{font-size:1rem}
  input.si{font-size:1.2rem}
}
/* Touch-friendly tap targets */
@media(hover:none){
  .btn,.myes,.mno,.btg,.skip{min-height:48px;display:flex;align-items:center;justify-content:center}
  .skip{display:inline-flex}
}
</style>
</head>
<body>
<div id="sky"></div>

<!-- PAGE 1: GATE -->
<div class="page" id="gate">
  <div class="gw">
    <div class="lily">
      <svg width="72" height="86" viewBox="0 0 80 90" fill="none">
        <path d="M40 84Q40 52 40 16" stroke="#6e9e6e" stroke-width="2.2" stroke-linecap="round"/>
        <path d="M28 70Q10 54 14 38Q26 50 28 70Z" fill="#82b582" opacity=".88"/>
        <path d="M52 70Q70 54 66 38Q54 50 52 70Z" fill="#82b582" opacity=".88"/>
        <ellipse cx="40" cy="16" rx="7" ry="9" fill="#f8ece6" opacity=".96"/>
        <ellipse cx="40" cy="30" rx="6.5" ry="8.5" fill="#f8ece6" opacity=".92"/>
        <ellipse cx="40" cy="44" rx="6" ry="8" fill="#f8ece6" opacity=".86"/>
        <line x1="28" y1="46" x2="18" y2="46" stroke="#6e9e6e" stroke-width="1.5"/>
        <ellipse cx="14" cy="46" rx="5" ry="6.5" fill="#f8ece6" opacity=".9"/>
        <line x1="27" y1="36" x2="17" y2="33" stroke="#6e9e6e" stroke-width="1.5"/>
        <ellipse cx="13" cy="31" rx="5" ry="6.5" fill="#f8ece6" opacity=".9"/>
        <line x1="52" y1="46" x2="62" y2="46" stroke="#6e9e6e" stroke-width="1.5"/>
        <ellipse cx="66" cy="46" rx="5" ry="6.5" fill="#f8ece6" opacity=".9"/>
        <line x1="53" y1="36" x2="63" y2="33" stroke="#6e9e6e" stroke-width="1.5"/>
        <ellipse cx="67" cy="31" rx="5" ry="6.5" fill="#f8ece6" opacity=".9"/>
      </svg>
    </div>
    <h1 class="gh">For You,<br><em>Always</em></h1>
    <p class="by">From Justin, With Love</p>
    <div class="card">
      <label class="fl" for="hn">Your Name, My Wubby Luvluv</label>
      <input class="fi" type="text" id="hn" placeholder="Write your name here…" autocomplete="off"/>
      <label class="fl" for="hd">The Day I Told You</label>
      <input class="fi" type="date" id="hd" min="2024-01-01" max="2026-12-31"/>
      <p class="hint">Hint: March 2026 🌸</p>
      <button class="btn" onclick="verify()">Open Our Story →</button>
      <p class="err" id="err"></p>
    </div>
  </div>
</div>

<!-- PAGE 2: SIGN -->
<div class="page hidden" id="sign">
  <div class="wrap">
    <div style="font-size:2.2rem;margin-bottom:14px">✍️</div>
    <h2 class="sh">Sign Your Name</h2>
    <p class="ss">Your signature seals our love</p>
    <div class="sc">
      <p class="sp">I, <span id="sn"></span>, choose you —<br>Justin Izeah Ramos Pingol — today and always. 💕</p>
      <input class="si" type="text" id="si" placeholder="Sign your full name…" autocomplete="off"/>
    </div>
    <button class="btn" onclick="goCert()">Please Say I Do 💍</button><br/>
    <span class="skip" onclick="restart()">sorry no</span>
    <div class="mb" id="modal">
      <div class="mbox">
        <div style="font-size:2.2rem">💍</div>
        <h3 class="mh">One More Thing…</h3>
        <p class="mbody">Would you like to take my surname,<br><strong>Pingol</strong>? 🌸</p>
        <div class="mbtns">
          <button class="myes" onclick="pick(true)">Yes, I will 💕</button>
          <button class="mno" onclick="pick(false)">Keep mine 🌷</button>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- PAGE 3: CERTIFICATE -->
<div class="page hidden" id="certificate">
  <div class="wrap">
    <div class="cout"><div class="cin">
      <span class="cc tl">✦</span><span class="cc tr">✦</span>
      <span class="cc bl">✦</span><span class="cc br">✦</span>
      <span class="clb">✦ Certificate of Virtual Marriage ✦</span>
      <h2 class="ctit">Two Hearts, One Promise</h2>
      <div style="width:90px;height:1px;margin:20px auto;background:linear-gradient(90deg,transparent,var(--blush),transparent)"></div>
      <div class="cnames" id="cn"></div>
      <div style="width:90px;height:1px;margin:20px auto;background:linear-gradient(90deg,transparent,var(--blush),transparent)"></div>
      <p class="cbody">United by love, sealed with a name,<br>and held together by every small moment.</p>
      <span class="cdate" id="cd"></span>
    </div></div>
    <button class="btg" onclick="restart()">Start Over ↺</button>
  </div>
</div>

<script>
const sky=document.getElementById('sky'),pc=[['#f5c0b0','#e89585'],['#f7d4c8','#ecb09a'],['#fce0d6','#f0bfb0']];
for(let i=0;i<22;i++){const d=document.createElement('div');d.className='petal';const c=pc[i%3];d.style.cssText=`background:radial-gradient(ellipse at 40% 35%,${c[0]},${c[1]});left:${Math.random()*100}vw;width:${9+Math.random()*13}px;height:${11+Math.random()*15}px;animation-duration:${9+Math.random()*12}s;animation-delay:${Math.random()*16}s`;sky.appendChild(d);}

let name='',sig='';
const DATE='2026-03-02',ME='Justin Izeah Ramos Pingol';

function verify(){
  const n=document.getElementById('hn').value.trim(),d=document.getElementById('hd').value;
  if(!n){showErr('Please enter your name, my wubby luvluv 💕');return;}
  if(d!==DATE){showErr("That doesn't seem right. Remember March 2, 2026? 🌸");return;}
  name=n;document.getElementById('err').style.display='none';
  document.getElementById('sn').textContent=name;
  document.getElementById('si').value='';
  show('sign');
}
function showErr(m){const e=document.getElementById('err');e.textContent=m;e.style.display='block';}
function show(id){document.querySelectorAll('.page').forEach(p=>p.classList.add('hidden'));document.getElementById(id).classList.remove('hidden');window.scrollTo({top:0,behavior:'smooth'});}
function goCert(){const s=document.getElementById('si').value.trim();if(!s){alert('Please sign your full name 💕');return;}if(s.split(/\s+/).length<2){alert('Please write your full name 💕');return;}sig=s;document.getElementById('modal').classList.add('open');}
function pick(yes){
  document.getElementById('modal').classList.remove('open');
  let n=sig;
  if(yes){const p=sig.trim().split(/\s+/);p[p.length-1]='Pingol';n=p.join(' ');}
  document.getElementById('cn').innerHTML=`${n} <span class="amp" style="color:var(--blush);font-size:.72em;font-style:normal">&amp;</span><br>${ME}`;
  document.getElementById('cd').textContent='Sealed with love · '+new Date().toLocaleDateString('en-US',{year:'numeric',month:'long',day:'numeric'});
  show('certificate');hearts();
}
function restart(){name='';document.getElementById('hn').value='';document.getElementById('hd').value='';document.getElementById('err').style.display='none';show('gate');}
function hearts(){const e=['💗','💕','💖','🌹','✨','💍','🌸'];for(let i=0;i<20;i++)setTimeout(()=>{const el=document.createElement('div');el.className='hb';el.textContent=e[~~(Math.random()*7)];el.style.cssText=`left:${8+Math.random()*84}vw;top:${25+Math.random()*55}vh`;document.body.appendChild(el);setTimeout(()=>el.remove(),2200);},i*110);}
</script>
</body>
</html>
